# -----------------------------------------------------------------------------
# 1. 核心依赖与构建 (Dependencies & Build)
# -----------------------------------------------------------------------------
node_modules/
dist/
build/
*.tsbuildinfo
package-lock.json

# -----------------------------------------------------------------------------
# 2. 环境配置与敏感信息 (Environment & Sensitive)
# -----------------------------------------------------------------------------
.env
!.env.example
gha-creds-*.json
*.pem

# -----------------------------------------------------------------------------
# 3. 日志与运行时数据 (Logs & Runtime Data)
# -----------------------------------------------------------------------------
*.log*
logs/
store/
data/
!data/.gitkeep
# 忽略群组的具体上下文和日志，保持 global/main 核心模板
groups/*/logs/
groups/*/CONTEXT.md
!groups/global/CONTEXT.md
!groups/main/CONTEXT.md

# -----------------------------------------------------------------------------
# 4. IDE 与 协作主体私有目录 (IDE & AI Agent Folders)
# -----------------------------------------------------------------------------
# 通用 IDE
.vscode/
.idea/
.husky/
.cache/
*.swp
*.swo

# 🟢 准许同步的活动主体 (Active Subject Memory)
!.antigravity/
!.cursor/
!.trae/
!.lingma/
!.joycode/
!.kiro/
!.qoder/
!.dropstone/
!.arts/
!.claude/
!.jules/

# 🔴 仍保持忽略或归档的主体
.gitnexus/
.iflow/
.comate/
.codebuddy/
.codebuddy-cn/
.pearai/
.catpawai/
.gemini-cli/
.codex/
.copilot/
.verdent/
.opencode/
.cascade/
.kimi-closeclaw/
.zed/
.codeflicker/
.codearts/
.coderider/
.junie/
.codeartsdoer/

# -----------------------------------------------------------------------------
# 5. 系统临时文件 (OS & Temporary)
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.tmp
*.temp
*_temp.*
temp.*
*_copy.*
*_out.*
logs-*.zip
*.tar

# -----------------------------------------------------------------------------
# 6. 项目内冗余/临时扫描文件 (Project Specific Junk)
# -----------------------------------------------------------------------------
# 忽略根目录及 scripts/ 目录下的所有临时 txt 日志/结果
/*.txt
/scripts/*.txt
!/docs/**/*.txt

# 忽略根目录下的单次修复脚本与调试文件
/fix*.ts
/fix*.js
/fix*.cjs
/head*.txt
/orig_head.txt
/reflog*.txt
/status.txt
/find*.txt
/fsck.txt
/snyk-code.sarif
/dangling_search.txt

# -----------------------------------------------------------------------------
# 7. 保留核心文档 (Force Keep Core Files)
# -----------------------------------------------------------------------------
!README.md
!RULES.md
!SECURITY.md
!CHANGELOG.md
!AGENTS.md
!CLAUDE.md
coverage/
