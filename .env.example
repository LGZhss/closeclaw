# ==========================================
# CloseClaw 环境变量配置模板
# ==========================================
# ⚠️ 注意：请将此文件重命名为 .env，并填入你自己的密钥
# ⚠️ 绝对不要将含有真实 Key 的 .env 提交到版本库！

# ==========================================
# 1. 核心鉴权配置 (REQUIRED)
# ==========================================

# Claude API Key (推荐使用 Claude 3.5/3.7 系列)
# 获取方式：https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 或者使用 Claude Code OAuth Token (从 ~/.claude/.credentials.json 获取)
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# 如果使用其他兼容 Anthropic API 的服务端点
# ANTHROPIC_BASE_URL=https://your-api-endpoint.com

# ==========================================
# 2. 通道配置 (OPTIONAL)
# ==========================================

# Telegram Bot Token (联系 @BotFather 获取)
# TELEGRAM_TOKEN=your-telegram-token-here

# 允许使用该 Bot 的 Telegram 用户 ID 列表（逗号分隔）
# TELEGRAM_ALLOWED_USER_IDS=your-telegram-user-id

# WhatsApp (使用 Baileys 库，首次运行会自动生成二维码)
# 无需额外配置，认证信息会自动保存到 store/auth/

# ==========================================
# 3. 系统与路径偏好 (OPTIONAL)
# ==========================================

# 助手名称 (用于触发词，默认：Andy)
# 触发词格式：@Andy
ASSISTANT_NAME=Andy

# 时区设置
TZ=Asia/Shanghai

# 最大并发容器数 (默认：5)
# MAX_CONCURRENT_CONTAINERS=5

# 容器超时时间 (毫秒，默认：1800000 = 30 分钟)
# CONTAINER_TIMEOUT=1800000

# 容器空闲超时时间 (毫秒，默认：1800000 = 30 分钟)
# IDLE_TIMEOUT=1800000

# 容器镜像名称
# CONTAINER_IMAGE=closeclaw-agent:latest
