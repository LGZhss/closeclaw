# ==========================================
# CloseClaw 环境变量配置模板
# ==========================================
# ⚠️ 注意：请将此文件重命名为 .env，并填入你自己的密钥
# ⚠️ 绝对不要将含有真实 Key 的 .env 提交到版本库！

# ==========================================
# 1. 核心鉴权配置 (REQUIRED)
# ==========================================

# Claude API Key (推荐使用 Claude 3.5/3.7 系列)
# 获取方式：https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 或者使用 Claude Code OAuth Token (从 ~/.claude/.credentials.json 获取)
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# 如果使用其他兼容 Anthropic API 的服务端点
# ANTHROPIC_BASE_URL=https://your-api-endpoint.com

# ==========================================
# 2. 免费 LLM API（推荐 - 无需 Key）
# ==========================================
# OpenRouter 提供免费模型，无需配置 Key 即可使用：
# - NVIDIA: Nemotron 3 Super, Nemotron Nano
# - Qwen: Qwen3 Coder 480B, Qwen3 Next 80B
# - Google: Gemma 3 4B/12B/27B
# - Meta: Llama 3.3 70B, Llama 3.2 3B
# - MiniMax: MiniMax M2.5
# - StepFun: Step 3.5 Flash
# - OpenAI: gpt-oss-120b, gpt-oss-20b
# - Mistral: Mistral Small 3.1 24B
# - Z.ai: GLM 4.5 Air
# - Nous: Hermes 3 405B
# 访问地址：https://openrouter.ai/

# GitHub Models 也提供免费模型（20+ 种）：
# - OpenAI: GPT-4o, GPT-4o mini, o1, o1-mini, o3, o3-mini
# - AI21: Jamba 1.5 Large
# - Microsoft: Phi-4, Phi-4-reasoning, Phi-4-mini
# 访问地址：https://models.github.ai/

# 如果需要访问更多模型，可配置以下 API Key：

# ==========================================
# 3. 聚合/备用 LLM API (OPTIONAL)
# ==========================================

# OpenRouter API (推荐，可访问 100+ 种模型)
# 获取方式：https://openrouter.ai/
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ModelScope API (阿里达摩院)
# 获取方式：https://modelscope.cn/
# MODELSCOPE_API_KEY=your-modelscope-api-key
# MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1

# Google Gemini API
# 获取方式：https://aistudio.google.com/
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.5-flash-preview

# NVIDIA API
# 获取方式：https://build.nvidia.com/
# NVIDIA_API_KEY=nvapi-your-key-here

# Zhipu AI (智谱清言)
# 获取方式：https://open.bigmodel.cn/
# ZHIPU_API_KEY=your-zhipu-api-key

# SiliconFlow (硅基流动)
# 获取方式：https://www.siliconflow.cn/
# SILICONFLOW_API_KEY=sk-your-key-here

# Cerebras Cloud
# 获取方式：https://cloud.cerebras.ai/
# CEREBRAS_API_KEY=csk-your-key-here

# Poixe (聚合平台)
# POIXE_API_KEY=your-poixe-api-key

# ==========================================
# 4. 可选付费 API（按需配置）
# ==========================================

# Mistral AI
# 获取方式：https://console.mistral.ai/
# MISTRAL_API_KEY=your-mistral-api-key

# Groq (高速推理)
# 获取方式：https://console.groq.com/
# GROQ_API_KEY=your-groq-api-key

# Cohere
# 获取方式：https://dashboard.cohere.com/
# COHERE_API_KEY=your-cohere-api-key

# Hyperbolic
# 获取方式：https://app.hyperbolic.xyz/
# HYPERBOLIC_API_KEY=your-hyperbolic-api-key

# Scaleway
# 获取方式：https://www.scaleway.com/
# SCALEWAY_API_KEY=your-scaleway-api-key

# Cloudflare
# 获取方式：https://developers.cloudflare.com/
# CLOUDFLARE_API_KEY=your-cloudflare-api-key

# Lambda Labs
# 获取方式：https://cloud.lambdalabs.com/
# LAMBDA_API_KEY=your-lambda-api-key

# ==========================================
# 5. 通道配置 (OPTIONAL)
# ==========================================

# Telegram Bot Token (联系 @BotFather 获取)
# TELEGRAM_TOKEN=your-telegram-token-here

# 允许使用该 Bot 的 Telegram 用户 ID 列表（逗号分隔）
# TELEGRAM_ALLOWED_USER_IDS=your-telegram-user-id

# ==========================================
# 6. 系统与路径偏好 (OPTIONAL)
# ==========================================

# 助手名称 (用于触发词)
# 触发词格式：@CloseClaw
ASSISTANT_NAME=CloseClaw

# 时区设置
TZ=Asia/Shanghai

# 工作区目录
WORKSPACE_DIR=E:\.closeclaw\data

# 默认模型提供商
# DEFAULT_PROVIDER=openrouter  # 使用 OpenRouter
# DEFAULT_PROVIDER=nvidia     # 使用 NVIDIA
# DEFAULT_PROVIDER=github     # 使用 GitHub Models
